generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x"]
    output = "/home/ubuntu/pflege_simulation_poc/nextjs_space/node_modules/.prisma/client"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

model User {
  id             String           @id @default(uuid())
  email          String           @unique
  passwordHash   String           @map("password_hash")
  nativeLanguage String           @default("tr") @map("native_language")
  createdAt      DateTime         @default(now()) @map("created_at")
  simulations    UserSimulation[]

  @@map("users")
}

model SimulationTemplate {
  id                 String           @id @default(uuid())
  domain             String           @default("nursing")
  type               String           @default("oral_exam")
  difficulty         String           @default("intermediate")
  titleDe            String           @map("title_de")
  titleTr            String           @map("title_tr")
  descriptionDe      String           @map("description_de") @db.Text
  descriptionTr      String           @map("description_tr") @db.Text
  systemPrompt       String           @map("system_prompt") @db.Text
  evaluationCriteria Json             @default("[]") @map("evaluation_criteria")
  maxTurns           Int              @default(8) @map("max_turns")
  simulations        UserSimulation[]

  @@map("simulation_templates")
}

model UserSimulation {
  id           String                  @id @default(uuid())
  userId       String                  @map("user_id")
  templateId   String                  @map("template_id")
  status       String                  @default("in_progress")
  languageMode String                  @default("bilingual") @map("language_mode")
  startedAt    DateTime                @default(now()) @map("started_at")
  completedAt  DateTime?               @map("completed_at")
  user         User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  template     SimulationTemplate      @relation(fields: [templateId], references: [id])
  interactions SimulationInteraction[]
  evaluation   Evaluation?

  @@map("user_simulations")
}

model SimulationInteraction {
  id           String         @id @default(uuid())
  simulationId String         @map("simulation_id")
  turnNumber   Int            @map("turn_number")
  userInput    String         @map("user_input") @db.Text
  aiResponse   String         @map("ai_response") @db.Text
  createdAt    DateTime       @default(now()) @map("created_at")
  simulation   UserSimulation @relation(fields: [simulationId], references: [id], onDelete: Cascade)

  @@map("simulation_interactions")
}

model Evaluation {
  id           String         @id @default(uuid())
  simulationId String         @unique @map("simulation_id")
  feedbackDe   String         @map("feedback_de") @db.Text
  feedbackTr   String         @map("feedback_tr") @db.Text
  scores       Json           @default("{}")
  createdAt    DateTime       @default(now()) @map("created_at")
  simulation   UserSimulation @relation(fields: [simulationId], references: [id], onDelete: Cascade)

  @@map("evaluations")
}

model GlossaryTerm {
  id        String @id @default(uuid())
  termDe    String @map("term_de")
  termTr    String @map("term_tr")
  contextDe String @map("context_de") @db.Text
  contextTr String @map("context_tr") @db.Text

  @@map("glossary_terms")
}
